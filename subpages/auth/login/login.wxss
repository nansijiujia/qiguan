.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 40rpx;
}

.login-container {
  width: 100%;
  max-width: 600rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 80rpx 50rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.logo-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo {
  font-size: 56rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 20rpx;
  letter-spacing: 4rpx;
}

.slogan {
  font-size: 26rpx;
  color: #6b7280;
  letter-spacing: 2rpx;
}

.login-content {
  width: 100%;
}

.welcome-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.welcome-icon {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 40rpx;
  background-color: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.icon-wechat {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: bold;
}

.welcome-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 20rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: #9ca3af;
}

.error-section {
  background-color: #fef2f2;
  border: 1rpx solid #fecaca;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
  text-align: center;
}

.error-msg {
  font-size: 26rpx;
  color: #dc2626;
  margin-bottom: 16rpx;
}

.retry-link {
  font-size: 24rpx;
  color: #3b82f6;
  text-decoration: underline;
}

.wechat-login-btn {
  width: 100%;
  height: 96rpx;
  background-color: #07C160;
  border-color: #07C160;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.wechat-login-btn::after {
  border: none;
}

.wechat-login-btn[disabled] {
  background-color: #07C160;
  border-color: #07C160;
  opacity: 0.8;
}

.btn-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.privacy-section {
  text-align: center;
  padding: 20rpx 0;
}

.privacy-text {
  font-size: 22rpx;
  color: #9ca3af;
}

.privacy-link {
  font-size: 22rpx;
  color: #3b82f6;
}
