/* profile.wxss */
.profile-page {
  min-height: 100vh;
  background-color: #f9fafb;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 30rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid #f0f0f0;
}

.nav-left {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.nav-right {
  width: 88rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.save-btn {
  font-size: 28rpx;
  color: #3b82f6;
  font-weight: 500;
}

.profile-content {
  margin-top: 20rpx;
  background-color: #ffffff;
}

.profile-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.avatar-item {
  align-items: flex-start;
  padding-top: 20rpx;
  padding-bottom: 20rpx;
  height: auto;
}

.item-label {
  font-size: 28rpx;
  color: #1f2937;
  width: 120rpx;
}

.item-input {
  flex: 1;
  font-size: 28rpx;
  color: #1f2937;
  text-align: right;
  padding: 0 10rpx;
}

.item-value {
  flex: 1;
  font-size: 28rpx;
  color: #6b7280;
  text-align: right;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.avatar-container {
  position: relative;
  margin-left: 20rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.avatar-upload {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: #3b82f6;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #ffffff;
}