<!-- customer-service/chat.wxml -->
<view class="chat-page">
  <!-- 顶部导航栏 -->
  <view class="top-nav">
    <view class="nav-left" bindtap="onBack">
      <icon type="back" size="24" color="#1f2937" />
    </view>
    <view class="nav-title">在线客服</view>
    <view class="nav-right">
      <view class="status-indicator">
        <view class="status-dot"></view>
        <text class="status-text">在线</text>
      </view>
    </view>
  </view>

  <!-- 聊天内容区域 -->
  <view class="chat-content" scroll-y="true">
    <!-- 系统消息 -->
    <view class="system-message">
      <text>客服小绮为您服务，请问有什么可以帮助您的？</text>
    </view>

    <!-- 客服消息 -->
    <view class="message-item service-message">
      <view class="message-avatar">
        <image src="/images/客服.png" mode="aspectFill" />
      </view>
      <view class="message-bubble">
        <text>您好，欢迎来到新绮梦之约，请问有什么可以帮助您的？</text>
      </view>
    </view>

    <!-- 用户消息 -->
    <view class="message-item user-message" wx:for="{{messages}}" wx:key="{{index}}">
      <view class="message-bubble">
        <text>{{item.content}}</text>
      </view>
      <view class="message-avatar">
        <image src="{{userInfo.avatar || '/images/我的.png'}}" mode="aspectFill" />
      </view>
    </view>
  </view>

  <!-- 消息输入区域 -->
  <view class="input-area">
    <input 
      class="message-input" 
      placeholder="请输入您的问题..." 
      bindinput="onInputChange"
      value="{{inputValue}}"
    />
    <button class="send-button" bindtap="sendMessage">发送</button>
  </view>
</view>