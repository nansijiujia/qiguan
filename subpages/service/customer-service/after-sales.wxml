<!-- customer-service/after-sales.wxml -->
<view class="after-sales-page">
  <!-- 顶部导航栏 -->
  <view class="top-nav">
    <view class="nav-left" bindtap="onBack">
      <icon type="back" size="24" color="#1f2937" />
    </view>
    <view class="nav-title">售后申请</view>
    <view class="nav-right"></view>
  </view>

  <!-- 售后类型选择 -->
  <view class="service-type-section">
    <view class="section-title">选择售后类型</view>
    <view class="service-type-options">
      <view 
        wx:for="{{serviceTypes}}" 
        wx:key="{{index}}"
        class="service-type-item {{selectedType === item.id ? 'active' : ''}}"
        bindtap="selectServiceType" 
        data-type="{{item.id}}"
      >
        <text>{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 订单选择 -->
  <view class="order-section">
    <view class="section-title">选择订单</view>
    <view class="order-list">
      <view 
        wx:for="{{orders}}" 
        wx:key="{{index}}"
        class="order-item {{selectedOrder === item.id ? 'active' : ''}}"
        bindtap="selectOrder" 
        data-order="{{item.id}}"
      >
        <view class="order-info">
          <view class="order-id">订单号：{{item.orderId}}</view>
          <view class="order-date">下单时间：{{item.date}}</view>
        </view>
        <view class="order-status">{{item.status}}</view>
      </view>
    </view>
  </view>

  <!-- 问题描述 -->
  <view class="description-section">
    <view class="section-title">问题描述</view>
    <textarea 
      class="description-input" 
      placeholder="请详细描述您遇到的问题..." 
      bindinput="onDescriptionChange"
      value="{{description}}"
      maxlength="500"
    />
    <view class="word-count">{{description.length}}/500</view>
  </view>

  <!-- 上传凭证 -->
  <view class="upload-section">
    <view class="section-title">上传凭证</view>
    <view class="upload-list">
      <view 
        wx:for="{{images}}" 
        wx:key="{{index}}"
        class="upload-item"
      >
        <image src="{{item}}" mode="aspectFill" />
        <view class="delete-icon" bindtap="deleteImage" data-index="{{index}}">
          <icon type="clear" size="20" color="#ef4444" />
        </view>
      </view>
      <view 
        wx:if="{{images.length < 5}}"
        class="upload-item upload-btn"
        bindtap="chooseImage"
      >
        <icon type="add" size="32" color="#9ca3af" />
        <text>上传图片</text>
      </view>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="contact-section">
    <view class="section-title">联系方式</view>
    <input 
      class="contact-input" 
      placeholder="请输入您的手机号" 
      bindinput="onContactChange"
      value="{{contact}}"
      type="number"
    />
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button 
      class="submit-button" 
      bindtap="submitApplication"
      disabled="{{!canSubmit}}"
    >
      提交申请
    </button>
  </view>
</view>