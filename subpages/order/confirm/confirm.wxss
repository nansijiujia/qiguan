/* order/confirm/confirm.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* 地址信息 */
.address-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.address-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.address-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.address-action {
  font-size: 28rpx;
  color: #3498db;
}

.address-content {
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
  min-height: 120rpx;
  display: flex;
  align-items: center;
}

.address-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

.address-placeholder {
  width: 100%;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 商品信息 */
.goods-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.goods-list {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.goods-item {
  display: flex;
  margin-bottom: 30rpx;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  margin-right: 20rpx;
  border-radius: 10rpx;
  overflow: hidden;
}

.goods-image image {
  width: 100%;
  height: 100%;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.goods-spec {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.goods-price {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  font-size: 30rpx;
  font-weight: bold;
  color: #e74c3c;
}

.quantity {
  font-size: 26rpx;
  color: #666;
}

/* 订单信息 */
.order-info-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.order-info-list {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.order-info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-info-label {
  font-size: 28rpx;
  color: #666;
}

.order-info-value {
  font-size: 28rpx;
  color: #333;
}

.order-info-item.total {
  margin-top: 10rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.total-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #e74c3c;
}

/* 支付方式 */
.payment-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.payment-list {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.payment-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.payment-item:last-child {
  border-bottom: none;
}

.payment-icon {
  width: 50rpx;
  height: 50rpx;
  margin-right: 20rpx;
}

.payment-icon image {
  width: 100%;
  height: 100%;
}

.payment-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.payment-select {
  width: 30rpx;
  height: 30rpx;
}

.payment-select image {
  width: 100%;
  height: 100%;
}

/* 底部结算栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  z-index: 100;
}

.total-price {
  display: flex;
  align-items: center;
}

.total-label {
  font-size: 28rpx;
  color: #666;
}

.total-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #e74c3c;
  margin-left: 10rpx;
}

.submit-btn {
  background-color: #3498db;
  color: #fff;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.submit-btn-text {
  color: #fff;
}