/* order/detail/detail.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

/* 订单状态 */
.status-section {
  background-color: #3498db;
  color: #fff;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
}

.status-icon image {
  width: 100%;
  height: 100%;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.status-desc {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 收货地址 */
.address-section {
  background-color: #fff;
  margin: 20rpx 0;
  padding: 30rpx;
}

.address-header {
  margin-bottom: 20rpx;
}

.address-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.address-content {
  padding: 20rpx;
  background-color: #f9f9f9;
  border-radius: 10rpx;
}

.address-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

/* 商品信息 */
.goods-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.goods-list {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.goods-item {
  display: flex;
  margin-bottom: 30rpx;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  margin-right: 20rpx;
  border-radius: 10rpx;
  overflow: hidden;
}

.goods-image image {
  width: 100%;
  height: 100%;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.goods-price {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  font-size: 30rpx;
  font-weight: bold;
  color: #e74c3c;
}

.quantity {
  font-size: 26rpx;
  color: #666;
}

/* 订单信息 */
.order-info-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.order-info-list {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.order-info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-info-label {
  font-size: 28rpx;
  color: #666;
}

.order-info-value {
  font-size: 28rpx;
  color: #333;
}

/* 价格信息 */
.price-section {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.price-label {
  font-size: 28rpx;
  color: #666;
}

.price-value {
  font-size: 28rpx;
  color: #333;
}

.price-item.total {
  margin-top: 10rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.total-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #e74c3c;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-top: 1rpx solid #eee;
  display: flex;
  padding: 20rpx 30rpx;
  z-index: 100;
}

.cancel-btn {
  flex: 1;
  border: 1rpx solid #ddd;
  border-radius: 50rpx;
  padding: 20rpx;
  margin-right: 20rpx;
  text-align: center;
}

.cancel-btn-text {
  font-size: 30rpx;
  color: #666;
}

.pay-btn {
  flex: 2;
  background-color: #e74c3c;
  border-radius: 50rpx;
  padding: 20rpx;
  text-align: center;
}

.pay-btn.disabled {
  background-color: #ccc;
}

.pay-btn-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

/* 发货按钮 */
.ship-btn {
  flex: 1;
  background-color: #3498db;
  border-radius: 50rpx;
  padding: 20rpx;
  text-align: center;
  margin: 0 auto;
  width: 80%;
}

.ship-btn-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

/* 物流按钮 */
.logistics-btn {
  flex: 1;
  background-color: #27ae60;
  border-radius: 50rpx;
  padding: 20rpx;
  text-align: center;
  margin-right: 10rpx;
}

.logistics-btn-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

/* 确认收货按钮 */
.confirm-btn {
  flex: 1;
  background-color: #e74c3c;
  border-radius: 50rpx;
  padding: 20rpx;
  text-align: center;
  margin-left: 10rpx;
}

.confirm-btn-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.query-btn {
  flex: 1;
  background-color: #3498db;
  border-radius: 50rpx;
  padding: 20rpx;
  text-align: center;
  margin: 0 auto;
  width: 80%;
}

.query-btn-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}