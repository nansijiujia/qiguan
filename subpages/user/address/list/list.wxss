.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.address-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.address-content {
  margin-bottom: 20rpx;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.phone {
  font-size: 30rpx;
  color: #666;
  margin-right: 20rpx;
}

.default-tag {
  background-color: #3498db;
  color: #fff;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.address-detail {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
}

.address-actions {
  display: flex;
  border-top: 1rpx solid #eee;
  padding-top: 16rpx;
}

.action-btn {
  margin-right: 30rpx;
  font-size: 28rpx;
  color: #666;
}

.action-btn text {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.action-btn text:hover {
  background-color: #f0f0f0;
}

.add-address-btn {
  background-color: #3498db;
  color: #fff;
  font-size: 32rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  text-align: center;
  margin-top: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(52, 152, 219, 0.3);
  transition: all 0.3s;
}

.add-address-btn:hover {
  background-color: #2980b9;
  transform: translateY(-2rpx);
}

.add-address-btn text {
  display: inline-block;
}
