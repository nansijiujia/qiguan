/* login.wxss */
.login-page {
  min-height: 100vh;
  background-color: #f9fafb;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 30rpx;
}

.login-container {
  width: 100%;
  max-width: 500rpx;
}

.logo-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo {
  font-size: 48rpx;
  font-weight: bold;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.slogan {
  font-size: 24rpx;
  color: #6b7280;
}

.form-section {
  width: 100%;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #d1d5db;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background-color: #ffffff;
}

.form-input:focus {
  border-color: #3b82f6;
  outline: none;
}

.login-btn {
  width: 100%;
  height: 80rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 12rpx;
  margin-top: 16rpx;
  margin-bottom: 32rpx;
}

.action-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.register-link {
  font-size: 24rpx;
  color: #3b82f6;
}

.forgot-link {
  font-size: 24rpx;
  color: #6b7280;
}