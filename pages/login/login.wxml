<!-- login.wxml -->
<view class="login-page">
  <view class="login-container">
    <view class="logo-section">
      <view class="logo">新绮梦之约</view>
      <view class="slogan">开启您的购物之旅</view>
    </view>
    
    <view class="form-section">
      <view class="form-item">
        <input 
          type="text" 
          placeholder="请输入手机号或用户名" 
          value="{{username}}" 
          bindinput="onUsernameInput"
          class="form-input"
        />
      </view>
      <view class="form-item">
        <input 
          type="password" 
          placeholder="请输入密码" 
          value="{{password}}" 
          bindinput="onPasswordInput"
          class="form-input"
        />
      </view>
      <button 
        type="primary" 
        bindtap="onLogin" 
        class="login-btn"
        loading="{{loading}}"
        disabled="{{loading}}"
      >
        登录
      </button>
      <view class="action-section">
        <text bindtap="goToRegister" class="register-link">立即注册</text>
        <text bindtap="onForgotPassword" class="forgot-link">忘记密码</text>
      </view>
    </view>
  </view>
</view>