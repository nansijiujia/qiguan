/* search.wxss */
.search-page {
  background-color: #f9fafb;
  min-height: 100vh;
}

/* 搜索栏 */
.search-header {
  background-color: #ffffff;
  padding: 10rpx 20rpx;
  border-bottom: 1rpx solid #e5e7eb;
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-input-container {
  display: flex;
  align-items: center;
  background-color: #f3f4f6;
  border-radius: 10rpx;
  padding: 10rpx 20rpx;
  height: 60rpx;
}

.search-icon {
  margin-right: 10rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1f2937;
  background: transparent;
  border: none;
  outline: none;
}

.cancel-btn {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #6366f1;
  padding: 0 10rpx;
}

/* 搜索内容区域 */
.search-content {
  padding: 20rpx;
}

/* 搜索历史 */
.search-history {
  margin-bottom: 30rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.clear-history {
  font-size: 26rpx;
  color: #6b7280;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.history-tag {
  background-color: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 15rpx;
  padding: 10rpx 20rpx;
  font-size: 26rpx;
  color: #4b5563;
  box-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

/* 热门搜索 */
.hot-search {
  margin-bottom: 30rpx;
}

.hot-header {
  margin-bottom: 20rpx;
}

.hot-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.hot-tag {
  background-color: #6366f1;
  color: #ffffff;
  border-radius: 15rpx;
  padding: 10rpx 20rpx;
  font-size: 26rpx;
  box-shadow: 0 2rpx 4rpx rgba(99, 102, 241, 0.3);
}

/* 搜索结果 */
.search-results {
  margin-top: 20rpx;
}

.results-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.results-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.results-count {
  font-size: 26rpx;
  color: #6b7280;
}

/* 无结果 */
.no-results {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  text-align: center;
}

.no-results-text {
  margin-top: 30rpx;
  font-size: 30rpx;
  color: #4b5563;
  font-weight: 500;
}

.no-results-hint {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #9ca3af;
}

/* 商品列表 */
.goods-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 20rpx;
}

.goods-item {
  background-color: #ffffff;
  border-radius: 15rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.goods-item:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.goods-image-container {
  position: relative;
  width: 100%;
  padding-bottom: 100%;
  overflow: hidden;
}

.goods-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.goods-item:hover .goods-image {
  transform: scale(1.05);
}

.goods-badge {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  background-color: #6366f1;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-weight: 500;
}

.goods-badge.hot {
  background-color: #ef4444;
}

.goods-badge.bestseller {
  background-color: #10b981;
}

.goods-badge.discount {
  background-color: #f59e0b;
}

.goods-info {
  padding: 15rpx;
}

.goods-title {
  font-size: 26rpx;
  color: #1f2937;
  margin-bottom: 10rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.goods-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.goods-price-container {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.goods-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #ef4444;
}

.goods-original-price {
  font-size: 22rpx;
  color: #9ca3af;
  text-decoration: line-through;
}

.add-to-cart-btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: #6366f1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
  box-shadow: 0 2rpx 4rpx rgba(99, 102, 241, 0.3);
}

.add-to-cart-btn::after {
  border: none;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 50rpx 0;
}

.loading::after {
  content: '';
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #e5e7eb;
  border-top: 4rpx solid #6366f1;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 动画效果 */
.fade-in {
  animation: fadeIn 0.3s ease-in-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 搜索建议 */
.search-suggestions {
  background-color: #ffffff;
  border-bottom: 1rpx solid #e5e7eb;
  max-height: 500rpx;
  overflow-y: auto;
  position: relative;
  z-index: 5;
}

.suggestion-item {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f3f4f6;
  transition: background-color 0.2s ease;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.suggestion-item:hover {
  background-color: #f9fafb;
}

.suggestion-icon {
  margin-right: 15rpx;
}

.suggestion-item text {
  font-size: 28rpx;
  color: #1f2937;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .goods-grid {
    gap: 15rpx;
  }
  
  .goods-info {
    padding: 10rpx;
  }
  
  .goods-title {
    font-size: 24rpx;
  }
  
  .goods-price {
    font-size: 28rpx;
  }
  
  .suggestion-item {
    padding: 15rpx 20rpx;
  }
  
  .suggestion-item text {
    font-size: 26rpx;
  }
}
