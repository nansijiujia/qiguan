<!-- change-password.wxml -->
<view class="change-password-page">
  <view class="nav-bar">
    <view class="nav-left" bindtap="onBack">
      <icon type="left" size="28" color="#1f2937" />
    </view>
    <view class="nav-title">修改密码</view>
  </view>
  
  <view class="form-section">
    <view class="form-item">
      <view class="item-label">旧密码</view>
      <input 
        type="password" 
        placeholder="请输入旧密码" 
        value="{{oldPassword}}" 
        bindinput="onOldPasswordInput"
        class="item-input"
      />
    </view>
    <view class="form-item">
      <view class="item-label">新密码</view>
      <input 
        type="password" 
        placeholder="请设置新密码（至少6位）" 
        value="{{newPassword}}" 
        bindinput="onNewPasswordInput"
        class="item-input"
      />
    </view>
    <view class="form-item">
      <view class="item-label">确认新密码</view>
      <input 
        type="password" 
        placeholder="请再次输入新密码" 
        value="{{confirmPassword}}" 
        bindinput="onConfirmPasswordInput"
        class="item-input"
      />
    </view>
    <button 
      type="primary" 
      bindtap="onSave" 
      class="save-btn"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      保存
    </button>
  </view>
</view>