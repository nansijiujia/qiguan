<view class="product-list-container">
  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view class="filter-item" bindtap="toggleFilter">
      <text>筛选</text>
      <image class="filter-icon" src="../../images/filter.png" wx:if="{{!showFilter}}" />
      <image class="filter-icon active" src="../../images/filter-active.png" wx:else />
    </view>
    
    <view class="sort-options">
      <view 
        class="sort-item {{filters.sortBy === 'default' ? 'active' : ''}}" 
        data-sort="default"
        bindtap="onSortChange"
      >
        综合
      </view>
      <view 
        class="sort-item {{filters.sortBy === 'sales' ? 'active' : ''}}" 
        data-sort="sales"
        bindtap="onSortChange"
      >
        销量
      </view>
      <view 
        class="sort-item {{filters.sortBy === 'price_asc' ? 'active' : ''}}" 
        data-sort="price_asc"
        bindtap="onSortChange"
      >
        价格↑
      </view>
      <view 
        class="sort-item {{filters.sortBy === 'price_desc' ? 'active' : ''}}" 
        data-sort="price_desc"
        bindtap="onSortChange"
      >
        价格↓
      </view>
      <view 
        class="sort-item {{filters.sortBy === 'new' ? 'active' : ''}}" 
        data-sort="new"
        bindtap="onSortChange"
      >
        新品
      </view>
    </view>
  </view>

  <!-- 筛选面板 -->
  <view class="filter-panel" wx:if="{{showFilter}}">
    <!-- 分类筛选 -->
    <view class="filter-section">
      <view class="filter-section-title">分类</view>
      <view class="category-list">
        <view 
          wx:for="{{categories}}" 
          wx:key="id"
          class="category-item {{filters.categoryId === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onCategoryChange"
        >
          {{item.name}}
        </view>
      </view>
    </view>

    <!-- 价格区间筛选 -->
    <view class="filter-section">
      <view class="filter-section-title">价格区间</view>
      <view class="price-range-list">
        <view 
          wx:for="{{priceRanges}}" 
          wx:key="label"
          class="price-range-item {{filters.priceRange.min === item.min && filters.priceRange.max === item.max ? 'active' : ''}}"
          data-range="{{item}}"
          bindtap="onPriceRangeChange"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 重置按钮 -->
    <view class="filter-actions">
      <view class="reset-btn" bindtap="onResetFilter">重置</view>
      <view class="confirm-btn" bindtap="toggleFilter">确认</view>
    </view>
  </view>

  <!-- 商品列表 -->
  <view class="product-grid">
    <view 
      wx:for="{{products}}" 
      wx:key="id"
      class="product-item"
      data-id="{{item.id}}"
      bindtap="onProductClick"
    >
      <!-- 商品图片 -->
      <view class="product-image">
        <image src="{{item.image || 'https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=modern%20sex%20toy%20product%20elegant%20design%20white%20background&image_size=square'}}" mode="aspectFill" />
        <view class="product-tag" wx:if="{{item.isNew}}">新品</view>
        <view class="product-tag hot" wx:if="{{item.isHot}}">热卖</view>
        <view class="product-tag bestseller" wx:if="{{item.isBestseller}}">爆款</view>
      </view>
      
      <!-- 商品信息 -->
      <view class="product-info">
        <view class="product-name">{{item.name || item.title}}</view>
        <view class="product-price">
          <text class="price">¥{{item.price}}</text>
          <text class="original-price" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
        </view>
        <view class="product-sales" wx:if="{{item.sales}}">已售{{item.sales}}件</view>
      </view>
      
      <!-- 添加到购物车按钮 -->
      <view class="add-to-cart" data-id="{{item.id}}" bindtap="onAddToCart">
        <image src="../../images/cart.png" mode="aspectFit" />
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-status" wx:if="{{loading && products.length === 0}}">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && products.length === 0}}">
    <image src="../../images/empty.png" mode="aspectFit" />
    <text>暂无商品</text>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{loading && products.length > 0}}">
    <text>加载中...</text>
  </view>
  <view class="load-more" wx:if="{{!loading && !pagination.hasMore && products.length > 0}}">
    <text>已加载全部</text>
  </view>
</view>
