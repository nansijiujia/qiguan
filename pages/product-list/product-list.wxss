.product-list-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 0 15rpx;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-right: 20rpx;
  position: relative;
}

.filter-item text {
  font-size: 28rpx;
  color: #333;
  margin-right: 8rpx;
}

.filter-icon {
  width: 20rpx;
  height: 20rpx;
  transition: transform 0.3s;
}

.filter-icon.active {
  transform: rotate(180deg);
}

.sort-options {
  display: flex;
  flex: 1;
  justify-content: space-around;
}

.sort-item {
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.sort-item.active {
  color: #ff4d4f;
  font-weight: 500;
}

.sort-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 30rpx;
  height: 4rpx;
  background-color: #ff4d4f;
  border-radius: 2rpx;
}

/* 筛选面板 */
.filter-panel {
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
  padding: 20rpx;
  margin-bottom: 10rpx;
}

.filter-section {
  margin-bottom: 30rpx;
}

.filter-section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.category-item {
  padding: 15rpx 25rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.category-item.active {
  background-color: #ff4d4f;
  color: #fff;
}

.price-range-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.price-range-item {
  padding: 15rpx 25rpx;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.price-range-item.active {
  background-color: #ff4d4f;
  color: #fff;
}

.filter-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.reset-btn {
  flex: 1;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
  text-align: center;
}

.confirm-btn {
  flex: 1;
  padding: 20rpx;
  background-color: #ff4d4f;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #fff;
  text-align: center;
}

/* 商品网格 */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
  padding: 15rpx;
}

.product-item {
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: relative;
  transition: transform 0.3s, box-shadow 0.3s;
}

.product-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.1);
}

.product-image {
  position: relative;
  width: 100%;
  padding-top: 100%;
  overflow: hidden;
}

.product-image image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-tag {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  padding: 5rpx 15rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  border-radius: 20rpx;
}

.product-tag.hot {
  background-color: #faad14;
}

.product-tag.bestseller {
  background-color: #52c41a;
}

.product-info {
  padding: 15rpx;
}

.product-name {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-price {
  display: flex;
  align-items: baseline;
  margin-bottom: 5rpx;
}

.price {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff4d4f;
  margin-right: 10rpx;
}

.original-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}

.product-sales {
  font-size: 22rpx;
  color: #999;
}

.add-to-cart {
  position: absolute;
  bottom: 15rpx;
  right: 15rpx;
  width: 50rpx;
  height: 50rpx;
  background-color: #ff4d4f;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(255, 77, 79, 0.3);
}

.add-to-cart image {
  width: 30rpx;
  height: 30rpx;
}

/* 加载状态 */
.loading-status {
  padding: 50rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  padding: 100rpx 0;
  text-align: center;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-state text {
  font-size: 28rpx;
  color: #999;
}

/* 加载更多 */
.load-more {
  padding: 30rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .product-grid {
    gap: 10rpx;
    padding: 10rpx;
  }
  
  .product-info {
    padding: 10rpx;
  }
  
  .product-name {
    font-size: 24rpx;
  }
  
  .price {
    font-size: 28rpx;
  }
}
