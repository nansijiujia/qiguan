<!-- order/list/list.wxml -->
<view class="container">
  <!-- 订单状态标签 -->
  <view class="status-tabs">
    <view class="tab-item {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">
      <text class="tab-text">全部</text>
    </view>
    <view class="tab-item {{activeTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">
      <text class="tab-text">待付款</text>
    </view>
    <view class="tab-item {{activeTab === 'paid' ? 'active' : ''}}" bindtap="switchTab" data-tab="paid">
      <text class="tab-text">待发货</text>
    </view>
    <view class="tab-item {{activeTab === 'shipped' ? 'active' : ''}}" bindtap="switchTab" data-tab="shipped">
      <text class="tab-text">待收货</text>
    </view>

  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view class="order-item" wx:for="{{orders}}" wx:key="{{item.id}}">
      <view class="order-header">
        <text class="order-id">订单号: {{item.orderId}}</text>
        <text class="order-status" wx:if="{{item.status === 'pending'}}">待付款</text>
        <text class="order-status" wx:elif="{{item.status === 'paid'}}">待发货</text>
        <text class="order-status" wx:elif="{{item.status === 'shipped'}}">待收货</text>

      </view>
      <view class="order-content">
        <view class="order-goods" wx:for="{{item.items}}" wx:key="{{goodsItem.productId}}" wx:for-item="goodsItem">
          <view class="goods-image">
            <image src="{{goodsItem.image}}" mode="aspectFill"></image>
          </view>
          <view class="goods-info">
            <text class="goods-name">{{goodsItem.name}}</text>
            <view class="goods-price">
              <text class="price">¥{{goodsItem.price.toFixed(2)}}</text>
              <text class="quantity">x{{goodsItem.quantity}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="order-footer">
        <text class="order-total">共{{item.items.length}}件商品，合计：</text>
        <text class="order-price">¥{{item.orderInfo.totalPrice.toFixed(2)}}</text>
      </view>
      <view class="order-actions">
        <button class="action-btn cancel-btn" wx:if="{{item.status === 'pending'}}" bindtap="cancelOrder" data-id="{{item.id}}">取消订单</button>
        <button class="action-btn pay-btn" wx:if="{{item.status === 'pending'}}" bindtap="payOrder" data-id="{{item.id}}">立即支付</button>
        <button class="action-btn view-btn" bindtap="viewOrder" data-id="{{item.id}}">查看详情</button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{orders.length === 0}}">
    <image src="/images/空购物车.png" mode="aspectFit"></image>
    <text class="empty-text">暂无订单</text>
    <button class="empty-btn" bindtap="goShopping">去购物</button>
  </view>
</view>