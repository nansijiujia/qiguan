<!-- order/detail/detail.wxml -->
<view class="container">
  <!-- 订单状态 -->
  <view class="status-section">
    <view class="status-icon" wx:if="{{order.status === 'pending'}}">
      <image src="/images/待付款.png" mode="aspectFit"></image>
    </view>
    <view class="status-icon" wx:elif="{{order.status === 'paid'}}">
      <image src="/images/待发货.png" mode="aspectFit"></image>
    </view>
    <view class="status-icon" wx:elif="{{order.status === 'shipped'}}">
      <image src="/images/待收货.png" mode="aspectFit"></image>
    </view>
    <view class="status-text" wx:if="{{order.status === 'pending'}}">待付款</view>
    <view class="status-text" wx:elif="{{order.status === 'paid'}}">已付款</view>
    <view class="status-text" wx:elif="{{order.status === 'shipped'}}">已发货</view>
    <view class="status-desc" wx:if="{{order.status === 'pending'}}">
      请在{{countdown}}分钟内完成支付，超时订单将自动取消
    </view>
    <view class="status-desc" wx:elif="{{order.status === 'shipped'}}">
      商品已发货，请注意查收
    </view>
  </view>

  <!-- 收货地址 -->
  <view class="address-section">
    <view class="address-header">
      <text class="address-title">收货地址</text>
    </view>
    <view class="address-content">
      <view class="address-name">{{order.address.name}} {{order.address.phone}}</view>
      <view class="address-detail">{{order.address.province}}{{order.address.city}}{{order.address.district}}{{order.address.detail}}</view>
    </view>
  </view>

  <!-- 商品信息 -->
  <view class="goods-section">
    <view class="section-header">
      <text class="section-title">商品信息</text>
    </view>
    <view class="goods-list">
      <view class="goods-item" wx:for="{{order.items}}" wx:key="{{item.productId}}">
        <view class="goods-image">
          <image src="{{item.image}}" mode="aspectFill"></image>
        </view>
        <view class="goods-info">
          <view class="goods-name">{{item.name}}</view>
          <view class="goods-price">
            <text class="price">¥{{item.price.toFixed(2)}}</text>
            <text class="quantity">x{{item.quantity}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 订单信息 -->
  <view class="order-info-section">
    <view class="section-header">
      <text class="section-title">订单信息</text>
    </view>
    <view class="order-info-list">
      <view class="order-info-item">
        <text class="order-info-label">订单编号</text>
        <text class="order-info-value">{{order.orderId}}</text>
      </view>
      <view class="order-info-item">
        <text class="order-info-label">创建时间</text>
        <text class="order-info-value">{{order.createdAt}}</text>
      </view>
      <view class="order-info-item">
        <text class="order-info-label">支付方式</text>
        <text class="order-info-value">{{order.paymentMethod === 'wechat' ? '微信支付' : '支付宝'}}</text>
      </view>
    </view>
  </view>

  <!-- 价格信息 -->
  <view class="price-section">
    <view class="price-item">
      <text class="price-label">商品总额</text>
      <text class="price-value">¥{{order.orderInfo.subtotal.toFixed(2)}}</text>
    </view>
    <view class="price-item">
      <text class="price-label">运费</text>
      <text class="price-value">¥{{order.orderInfo.shippingFee.toFixed(2)}}</text>
    </view>
    <view class="price-item">
      <text class="price-label">优惠</text>
      <text class="price-value">-¥{{order.orderInfo.discount.toFixed(2)}}</text>
    </view>
    <view class="price-item total">
      <text class="price-label">实付金额</text>
      <text class="price-value total-price">¥{{order.orderInfo.totalPrice.toFixed(2)}}</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar" wx:if="{{order.status === 'pending'}}">
    <view class="cancel-btn" bindtap="cancelOrder">
      <text class="cancel-btn-text">取消订单</text>
    </view>
    <view class="pay-btn" bindtap="payOrder">
      <text class="pay-btn-text">立即支付</text>
    </view>
  </view>
  <view class="bottom-bar" wx:elif="{{order.status === 'paid'}}">
    <view class="ship-btn" bindtap="shipOrder">
      <text class="ship-btn-text">发货</text>
    </view>
  </view>
  <view class="bottom-bar" wx:elif="{{order.status === 'shipped'}}">
    <view class="logistics-btn" bindtap="getLogistics">
      <text class="logistics-btn-text">查看物流</text>
    </view>
    <view class="confirm-btn" bindtap="confirmReceipt">
      <text class="confirm-btn-text">确认收货</text>
    </view>
  </view>
</view>