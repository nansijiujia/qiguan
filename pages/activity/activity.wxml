<!-- activity.wxml - 活动列表页面 -->
<view class="activity-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">活动中心</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="error-container">
    <text class="error-icon">⚠️</text>
    <text class="error-message">{{errorMessage}}</text>
    <button class="retry-button" bindtap="reloadData">重新加载</button>
  </view>

  <!-- 活动列表 -->
  <view wx:else class="activity-list">
    <view wx:if="{{activities.length === 0}}" class="empty-container">
      <text class="empty-icon">🎉</text>
      <text class="empty-text">暂无活动</text>
      <text class="empty-subtext">敬请期待更多精彩活动</text>
    </view>
    <view wx:else>
      <view wx:for="{{activities}}" wx:key="id"
            class="activity-item"
            bindtap="goToActivityDetail"
            data-id="{{item.id}}">
      <!-- 活动类型标签 -->
      <view class="activity-type" style="background-color: {{item.typeConfig.color}}">
        <text class="type-icon">{{item.typeConfig.icon}}</text>
        <text class="type-text">{{item.typeConfig.text}}</text>
      </view>

      <!-- 活动信息 -->
      <view class="activity-info">
        <text class="activity-title">{{item.name}}</text>
        <text class="activity-description">{{item.description || '暂无描述'}}</text>
        
        <!-- 活动时间 -->
        <view class="activity-time">
          <text class="time-icon">⏰</text>
          <text class="time-text">{{item.startDate}} 至 {{item.endDate}}</text>
        </view>

        <!-- 活动统计 -->
        <view class="activity-stats">
          <view class="stat-item">
            <text class="stat-icon">👁️</text>
            <text class="stat-text">{{item.views}} 浏览</text>
          </view>
          <view class="stat-item">
            <text class="stat-icon">🎯</text>
            <text class="stat-text">{{item.participationCount}} 参与</text>
          </view>
        </view>
      </view>

      <!-- 箭头图标 -->
      <view class="activity-arrow">
        <text class="arrow-icon">→</text>
      </view>
      </view>
    </view>
  </view>
</view>