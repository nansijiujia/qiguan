.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.form-item {
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
}

.label {
  width: 120rpx;
  font-size: 30rpx;
  color: #333;
}

input, textarea {
  flex: 1;
  font-size: 30rpx;
  padding: 10rpx 0;
  border: none;
  outline: none;
}

textarea {
  height: 150rpx;
  resize: none;
  line-height: 1.5;
}

.region-picker {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.placeholder {
  color: #999;
}

.checkbox-item {
  justify-content: flex-start;
  padding-left: 20rpx;
}

checkbox {
  margin-right: 10rpx;
  transform: scale(1.2);
}

.submit-btn {
  margin-top: 40rpx;
  background-color: #3498db;
  color: #fff;
  font-size: 32rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  border: none;
  outline: none;
  box-shadow: 0 4rpx 12rpx rgba(52, 152, 219, 0.3);
  transition: all 0.3s;
}

.submit-btn:hover {
  background-color: #2980b9;
  transform: translateY(-2rpx);
}
