<view class="empty-container" wx:if="{{visible}}">
  <view class="empty-content">
    <image class="empty-icon" src="{{icon}}" mode="aspectFit" />
    <text class="empty-text">{{text}}</text>
    <button wx:if="{{buttonText}}" class="empty-button" bindtap="handleButtonClick">
      {{buttonText}}
    </button>
  </view>
</view>