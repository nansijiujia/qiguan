<view class="countdown-container" wx:if="{{visible}}">
  <view class="countdown-title">{{title}}</view>
  <view class="countdown-time">
    <view class="countdown-item">
      <text class="countdown-number">{{days}}</text>
      <text class="countdown-label">天</text>
    </view>
    <view class="countdown-separator">:</view>
    <view class="countdown-item">
      <text class="countdown-number">{{hours}}</text>
      <text class="countdown-label">时</text>
    </view>
    <view class="countdown-separator">:</view>
    <view class="countdown-item">
      <text class="countdown-number">{{minutes}}</text>
      <text class="countdown-label">分</text>
    </view>
    <view class="countdown-separator">:</view>
    <view class="countdown-item">
      <text class="countdown-number">{{seconds}}</text>
      <text class="countdown-label">秒</text>
    </view>
  </view>
</view>