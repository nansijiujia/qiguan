{
  "type": "object",
  "properties": {
    "functionsRoot": {
      "type": "string",
      "description": "Root directory of the functions"
    },
    "functions": {
      "type": "array",
      "description": "Functions to be deployed",
      "items": {
        "type": "object",
        "nullable": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Unique name of the function"
          },
          "directory": {
            "type": "string",
            "description": "Directory of the function"
          },
          "source": {
            "type": "string",
            "nullable": true,
            "description": "Source file of the function"
          },
          "target": {
            "type": "string",
            "nullable": true,
            "description": "Target function of the function"
          },
          "triggerPath": {
            "type": "string",
            "nullable": true,
            "description": "Request path for function routing"
          }
        },
        "required": ["name", "directory"]
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "nullable": false,
        "properties": {
          "path": {
            "type": "string",
            "nullable": false,
            "minLength": 1,
            "description": "Request path for function routing"
          },
          "functionName": {
            "type": "string",
            "nullable": false,
            "description": "Target function name for function routing as defined in functions"
          }
        },
        "required": ["functionName", "path"]
      }
    }
  },
  "required": []
}
