#!/bin/bash

# ============================================================
# 绮管电商后台 - Git post-receive 自动部署脚本 (增强版)
# ============================================================
# 功能:
#   - 自动检测Git推送并触发部署
#   - 部署前健康检查和环境验证
#   - 自动备份当前版本
#   - 失败时自动回滚到上一版本
#   - 完整的日志记录和通知
#   - 文件锁防止并发部署
#
# 用法:
#   此脚本由Git自动调用，无需手动执行
#   放置位置: /home/git/repo.git/hooks/post-receive
#
# 触发条件:
#   仅处理推送到 "绮管" 分支的代码
#
# 作者: 绮管技术团队
# 日期: 2026-04-08
# 版本: v2.0 (增强版)
# ============================================================

set -e

# ==================== 配置区 ====================
GIT_DIR="/home/git/repo.git"
WORK_TREE="/var/www/qiguan"
LOG_DIR="/var/log/qiguan/deploy"
BACKUP_DIR="/var/www/qiguan/backups"
DEPLOY_LOG="/var/log/qiguan/deploy.log"
ROLLBACK_LOG="/var/log/qiguan/rollback.log"
LOCK_FILE="/tmp/qiguan_deploy.lock"
NOTIFICATION_LOG="/var/log/qiguan/notification.log"

# 服务器信息
SERVER_IP="101.34.39.231"
DOMAIN="qimengzhiyue.cn"

# PM2进程名
PM2_BACKEND="qiguan-backend"
PM2_FRONTEND="qiguan-frontend"

# Node.js路径
NODE_PATH="/usr/local/node"
export PATH="$NODE_PATH/bin:$PATH"

# 时间戳格式
TIMESTAMP=$(date '+%Y%m%d_%H%M%S')
DATE_FORMAT='+%Y-%m-%d %H:%M:%S'

# 备份保留数量
MAX_BACKUPS=5

# 健康检查URL
HEALTH_CHECK_URL="http://localhost:3000/api/health"

# 超时设置 (秒)
TIMEOUT_INSTALL=300      # npm install超时
TIMEOUT_BUILD=600        # npm run build超时
TIMEOUT_RESTART=60       # PM2重启超时
TIMEOUT_HEALTHCHECK=30   # 健康检查超时
# ================================================

# ==================== 颜色定义 ====================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color
# ================================================

# ==================== 初始化环境 ====================
mkdir -p "$LOG_DIR" "$BACKUP_DIR" "$(dirname "$DEPLOY_LOG")" "$(dirname "$ROLLBACK_LOG")" "$(dirname "$NOTIFICATION_LOG")" "$WORK_TREE"

# 重定向所有输出到日志文件
exec > >(tee -a "$LOG_DIR/deploy_${TIMESTAMP}.log") 2>&1
# ================================================

# ==================== 工具函数 ====================

# 日志函数 (带时间戳和颜色)
log() {
    local level=$1
    shift
    local message=$*
    local timestamp=$(date "$DATE_FORMAT")
    local color=""
    
    case $level in
        "INFO")    color=$GREEN ;;
        "WARN")    color=$YELLOW ;;
        "ERROR")   color=$RED ;;
        "SUCCESS") color=$GREEN ;;
        "DEBUG")   color=$BLUE ;;
        *)         color=$NC ;;
    esac
    
    echo -e "${color}[${timestamp}] [${level}] ${message}${NC}"
    
    # 同时写入汇总日志
    echo "[${timestamp}] [${level}] ${message}" >> "$DEPLOY_LOG"
}

# 错误退出函数
error_exit() {
    local error_msg="$1"
    log "ERROR" "❌ 错误: $error_msg"
    
    # 记录错误到通知日志
    echo "[$(date "$DATE_FORMAT")] [ERROR] 部署失败: $error_msg" >> "$NOTIFICATION_LOG"
    
    # 清理锁文件
    if [ -f "$LOCK_FILE" ]; then
        rm -f "$LOCK_FILE"
        log "INFO" "已清理锁文件"
    fi
    
    exit 1
}

# 成功完成函数
success_exit() {
    local success_msg="$1"
    log "SUCCESS" "✅ $success_msg"
    
    # 记录成功到通知日志
    echo "[$(date "$DATE_FORMAT")] [SUCCESS] 部署成功: $success_msg" >> "$NOTIFICATION_LOG"
    
    # 清理锁文件
    rm -f "$LOCK_FILE"
    
    exit 0
}

# 清理函数 (trap)
cleanup() {
    local exit_code=$?
    if [ $exit_code -ne 0 ]; then
        log "ERROR" "部署异常终止 (退出码: $exit_code)"
    fi
    log "INFO" "🧹 正在清理资源..."
    rm -f "$LOCK_FILE"
}
trap cleanup EXIT

# 发送通知 (可扩展为Webhook/邮件/钉钉等)
send_notification() {
    local status="$1"
    local message="$2"
    local timestamp=$(date "$DATE_FORMAT")
    
    # 写入通知日志 (后续可扩展为实际的通知服务)
    cat >> "$NOTIFICATION_LOG" << EOF
[${timestamp}] [${status}] ${message}
----------------------------------------
服务器: ${SERVER_IP} (${DOMAIN})
分支: ${BRANCH:-unknown}
时间: ${timestamp}
EOF
    
    log "INFO" "📢 已记录部署通知: [$status] $message"
    
    # TODO: 可在此处添加Webhook/邮件/钉钉通知代码
    # 例如:
    # curl -X POST -H 'Content-type: application/json' \
    #     --data "{\"text\":\"${message}\"}" \
    #     https://hooks.slack.com/services/xxx
}
# ================================================

# ==================== 核心功能函数 ====================

# 检查并获取文件锁
acquire_lock() {
    log "INFO" "🔒 检查部署锁..."
    
    if [ -f "$LOCK_FILE" ]; then
        local lock_pid=$(cat "$LOCK_FILE")
        
        # 检查进程是否还在运行
        if kill -0 "$lock_pid" 2>/dev/null; then
            local lock_time=$(stat -c %Y "$LOCK_FILE" 2>/dev/null || stat -f %m "$LOCK_FILE")
            local current_time=$(date +%s)
            local elapsed=$((current_time - lock_time))
            
            error_exit "部署正在进行中 (PID: ${lock_pid}, 已运行: ${elapsed}秒)，请稍后再试"
        else
            log "WARN" "⚠️ 发现过期锁文件 (PID: ${lock_pid} 已不存在)，正在清除..."
            rm -f "$LOCK_FILE"
        fi
    fi
    
    # 创建新锁
    echo $$ > "$LOCK_FILE"
    log "SUCCESS" "✅ 获取部署锁成功 (PID: $$)"
}

# 健康检查函数
health_check() {
    log "INFO" "🏥 开始健康检查..."
    local check_passed=true
    
    # 检查Node.js
    log "INFO" "检查Node.js..."
    if command -v node &> /dev/null; then
        local node_version=$(node --version)
        local major_version=$(echo "$node_version" | cut -d'.' -f1 | tr -d 'v')
        
        if [ "$major_version" -ge 18 ] 2>/dev/null; then
            log "SUCCESS" "✅ Node.js 版本: $node_version (符合要求 >=18.x)"
        else
            log "ERROR" "❌ Node.js 版本过低: $node_version (要求 >=18.x)"
            check_passed=false
        fi
    else
        log "ERROR" "❌ Node.js 未找到或不可用"
        check_passed=false
    fi
    
    # 检查npm
    log "INFO" "检查npm..."
    if command -v npm &> /dev/null; then
        local npm_version=$(npm --version)
        log "SUCCESS" "✅ npm 版本: $npm_version"
    else
        log "ERROR" "❌ npm 未找到或不可用"
        check_passed=false
    fi
    
    # 检查PM2
    log "INFO" "检查PM2..."
    if command -v pm2 &> /dev/null; then
        local pm2_version=$(pm2 --version 2>/dev/null || echo "unknown")
        log "SUCCESS" "✅ PM2 版本: $pm2_version"
    else
        log "ERROR" "❌ PM2 未安装或不在PATH中"
        check_passed=false
    fi
    
    # 检查磁盘空间 (至少需要500MB)
    log "INFO" "检查磁盘空间..."
    local available_space=$(df -BG "$WORK_TREE" | awk 'NR==2 {print $4}' | tr -d 'G')
    if [ "$available_space" -ge 500 ] 2>/dev/null; then
        log "SUCCESS" "✅ 磁盘空间充足: ${available_space}MB 可用 (要求 >=500MB)"
    else
        log "ERROR" "❌ 磁盘空间不足: ${available_space:-未知}MB 可用 (要求 >=500MB)"
        check_passed=false
    fi
    
    # 检查内存 (至少需要256MB可用)
    log "INFO" "检查内存空间..."
    local available_mem=$(free -m | awk '/Mem:/ {print $7}')
    if [ "$available_mem" -ge 256 ] 2>/dev/null; then
        log "SUCCESS" "✅ 内存充足: ${available_mem}MB 可用 (要求 >=256MB)"
    else
        log "WARN" "⚠️ 内存较低: ${available_mem:-未知}MB 可用 (建议 >=256MB)"
        # 内存不足不阻止部署，仅警告
    fi
    
    # 检查.env文件
    log "INFO" "检查环境配置..."
    if [ -f "$WORK_TREE/.env" ]; then
        log "SUCCESS" "✅ .env 文件存在"
        
        # 检查必需的环境变量
        local required_vars=("PORT" "NODE_ENV" "JWT_SECRET")
        local missing_vars=()
        
        for var in "${required_vars[@]}"; do
            if grep -q "^${var}=" "$WORK_TREE/.env"; then
                : # 变量存在
            else
                missing_vars+=("$var")
            fi
        done
        
        if [ ${#missing_vars[@]} -eq 0 ]; then
            log "SUCCESS" "✅ 所有必需环境变量已配置"
        else
            log "WARN" "⚠️ 缺少环境变量: ${missing_vars[*]}"
        fi
    else
        log "WARN" "⚠️ .env 文件不存在，将使用默认配置"
    fi
    
    if [ "$check_passed" = false ]; then
        error_exit "健康检查未通过，请查看上方错误信息"
    fi
    
    log "SUCCESS" "✅ 所有健康检查通过"
}

# 备份当前版本
backup_current_version() {
    log "INFO" "📦 正在备份当前版本..."
    
    local backup_name="${TIMESTAMP}"
    local backup_path="${BACKUP_DIR}/${backup_name}"
    
    # 创建备份目录
    mkdir -p "$backup_path"
    
    # 备份关键文件和目录
    local backup_items=(
        "package.json"
        "package-lock.json"
        ".env"
        "ecosystem.config.js"
        "functions/"
        "routes/"
        "middleware/"
        "db.js"
        "index.js"
        "qiguanqianduan/dist"
    )
    
    for item in "${backup_items[@]}"; do
        if [ -e "$WORK_TREE/$item" ]; then
            cp -r "$WORK_TREE/$item" "$backup_path/" 2>/dev/null && \
                log "DEBUG" "已备份: $item" || \
                log "WARN" "备份失败: $item (可能不存在)"
        fi
    done
    
    # 记录备份信息
    cat > "$backup_path/backup_info.txt" << EOF
备份时间: $(date "$DATE_FORMAT")
备份版本: ${backup_name}
Git提交: $(cd "$WORK_TREE" && git rev-parse HEAD 2>/dev/null || echo "unknown")
分支: $(cd "$WORK_TREE" && git branch --show-current 2>/dev/null || echo "unknown")
备份原因: 部署前自动备份
EOF
    
    log "SUCCESS" "✅ 备份完成: $backup_path"
    
    # 清理旧备份 (保留最近MAX_BACKUPS个)
    cleanup_old_backups
}

# 清理旧备份
cleanup_old_backups() {
    local backup_count=$(ls -1d "$BACKUP_DIR"/[0-9]* 2>/dev/null | wc -l)
    
    if [ "$backup_count" -gt "$MAX_BACKUPS" ]; then
        log "INFO" "🧹 清理旧备份 (保留最近 ${MAX_BACKUPS} 个)..."
        
        # 找出最旧的备份并删除
        ls -1dt "$BACKUP_DIR"/[0-9]* 2>/dev/null | tail -n +$((MAX_BACKUPS + 1)) | while read old_backup; do
            rm -rf "$old_backup"
            log "DEBUG" "已删除旧备份: $old_backup"
        done
        
        log "INFO" "旧备份清理完成"
    fi
}

# 回滚到指定备份版本
rollback_to_backup() {
    local backup_path="$1"
    local reason="$2"
    
    log "WARN" "⚠️ 开始回滚操作..."
    log "WARN" "回滚原因: $reason"
    
    # 记录回滚日志
    echo "[$(date "$DATE_FORMAT")] 回滚开始" >> "$ROLLBACK_LOG"
    echo "目标备份: $backup_path" >> "$ROLLBACK_LOG"
    echo "回滚原因: $reason" >> "$ROLLBACK_LOG"
    
    # 验证备份是否存在
    if [ ! -d "$backup_path" ]; then
        log "ERROR" "❌ 备份目录不存在: $backup_path"
        return 1
    fi
    
    # 停止当前服务
    log "INFO" "停止当前PM2服务..."
    pm2 stop all 2>/dev/null || true
    
    # 恢复备份文件
    log "INFO" "正在恢复备份文件..."
    cp -rf "$backup_path/"* "$WORK_TREE/" 2>/dev/null
    
    # 重启服务
    log "INFO" "正在重启PM2服务..."
    pm2 restart all 2>&1 || \
        pm2 start "$WORK_TREE/ecosystem.config.js" --env production 2>&1 || {
            log "ERROR" "❌ 回滚后服务启动失败！需要手动干预"
            echo "[$(date "$DATE_FORMAT")] 回滚失败: 服务启动失败" >> "$ROLLBACK_LOG"
            return 1
        }
    
    # 等待服务启动
    sleep 5
    
    # 验证服务状态
    if pm2 list | grep -q "online"; then
        log "SUCCESS" "✅ 回滚成功！服务已恢复到备份版本"
        echo "[$(date "$DATE_FORMAT")] 回滚成功" >> "$ROLLBACK_LOG"
        send_notification "ROLLBACK_SUCCESS" "已回滚到版本: $(basename $backup_path)，原因: $reason"
        return 0
    else
        log "ERROR" "❌ 回滚后服务状态异常！需要手动干预"
        echo "[$(date "$DATE_FORMAT")] 回滚失败: 服务状态异常" >> "$ROLLBACK_LOG"
        send_notification "ROLLBACK_FAILED" "回滚失败，需要手动干预！"
        return 1
    fi
}

# 获取最新备份路径
get_latest_backup() {
    local latest=$(ls -1dt "$BACKUP_DIR"/[0-9]* 2>/dev/null | head -1)
    echo "$latest"
}

# 安装依赖
install_dependencies() {
    log "INFO" "📦 正在安装依赖 (npm install)..."
    log "INFO" "超时设置: ${TIMEOUT_INSTALL}秒"
    
    cd "$WORK_TREE"
    
    # 使用timeout命令控制超时
    if timeout "$TIMEOUT_INSTALL" npm install --production=false 2>&1; then
        log "SUCCESS" "✅ npm install 完成"
        return 0
    else
        local exit_code=$?
        if [ $exit_code -eq 124 ]; then
            log "ERROR" "❌ npm install 超时 (>${TIMEOUT_INSTALL}秒)"
        else
            log "ERROR" "❌ npm install 失败 (退出码: $exit_code)"
        fi
        
        # 自动回滚
        local latest_backup=$(get_latest_backup)
        if [ -n "$latest_backup" ] && [ -d "$latest_backup" ]; then
            log "WARN" "正在自动回滚到上一个版本..."
            rollback_to_backup "$latest_backup" "npm install 失败"
        fi
        
        error_exit "依赖安装失败，已尝试自动回滚"
    fi
}

# 构建项目
build_project() {
    log "INFO" "🔨 正在构建项目 (npm run build)..."
    log "INFO" "超时设置: ${TIMEOUT_BUILD}秒"
    
    cd "$WORK_TREE"
    
    # 使用timeout命令控制超时
    if timeout "$TIMEOUT_BUILD" npm run build 2>&1; then
        log "SUCCESS" "✅ 构建完成"
        return 0
    else
        local exit_code=$?
        if [ $exit_code -eq 124 ]; then
            log "ERROR" "❌ 构建超时 (>${TIMEOUT_BUILD}秒)"
        else
            log "ERROR" "❌ 构建失败 (退出码: $exit_code)"
        fi
        
        # 自动回滚
        local latest_backup=$(get_latest_backup)
        if [ -n "$latest_backup" ] && [ -d "$latest_backup" ]; then
            log "WARN" "正在自动回滚到上一个版本..."
            rollback_to_backup "$latest_backup" "构建失败"
        fi
        
        error_exit "项目构建失败，已尝试自动回滚"
    fi
}

# 重启服务
restart_services() {
    log "INFO" "🔄 正在重启PM2服务..."
    log "INFO" "超时设置: ${TIMEOUT_RESTART}秒"
    
    cd "$WORK_TREE"
    
    # 尝试使用pm2 restart
    if timeout "$TIMEOUT_RESTART" pm2 restart all 2>&1; then
        log "SUCCESS" "✅ PM2 restart 成功"
        
        # 等待服务启动
        log "INFO" "等待服务启动..."
        sleep 5
        
        # 验证服务状态
        if pm2 list | grep -E "(qiguan-backend|qiguan-frontend)" | grep -q "online"; then
            log "SUCCESS" "✅ 所有服务运行正常"
            return 0
        else
            log "WARN" "⚠️ 部分服务状态异常，尝试使用pm2 start..."
        fi
    else
        log "WARN" "⚠️ pm2 restart 失败，尝试使用 pm2 start..."
    fi
    
    # 如果restart失败，尝试start
    if timeout "$TIMEOUT_RESTART" pm2 start ecosystem.config.js --env production 2>&1; then
        log "SUCCESS" "✅ PM2 start 成功"
        sleep 5
        
        if pm2 list | grep -E "(qiguan-backend|qiguan-frontend)" | grep -q "online"; then
            log "SUCCESS" "✅ 所有服务运行正常"
            return 0
        fi
    fi
    
    # 启动失败，自动回滚
    log "ERROR" "❌ PM2 服务启动失败"
    local latest_backup=$(get_latest_backup)
    if [ -n "$latest_backup" ] && [ -d "$latest_backup" ]; then
        log "WARN" "正在自动回滚到上一个版本..."
        rollback_to_backup "$latest_backup" "PM2服务启动失败"
    fi
    
    error_exit "服务重启失败，已尝试自动回滚"
}

# 健康验证 (可选)
verify_deployment() {
    log "INFO" "🏥 正在进行部署后健康验证..."
    log "INFO" "超时设置: ${TIMEOUT_HEALTHCHECK}秒"
    
    # 等待服务完全启动
    sleep 3
    
    # 尝试访问健康检查端点
    local http_code=$(timeout "$TIMEOUT_HEALTHCHECK" curl -s -o /dev/null -w "%{http_code}" "$HEALTH_CHECK_URL" 2>/dev/null || echo "000")
    
    if [ "$http_code" = "200" ]; then
        log "SUCCESS" "✅ 健康检查通过 (HTTP $http_code)"
        return 0
    elif [ "$http_code" = "000" ]; then
        log "WARN" "⚠️ 无法连接到健康检查端点 (服务可能仍在启动中)"
        # 不阻止部署，仅警告
        return 0
    else
        log "WARN" "⚠️ 健康检查返回非200状态码: HTTP $http_code"
        # 不阻止部署，但记录警告
        return 0
    fi
}

# 清理旧日志
cleanup_old_logs() {
    log "INFO" "🧹 清理旧日志文件 (保留最近7天)..."
    find "$LOG_DIR" -name "deploy_*.log" -mtime +7 -delete 2>/dev/null || true
    log "INFO" "日志清理完成"
}

# 显示部署统计
show_deploy_stats() {
    local total_deploys=$(grep -c "部署完成\|部署失败" "$DEPLOY_LOG" 2>/dev/null || echo 0)
    local success_deploys=$(grep -c "部署完成" "$DEPLOY_LOG" 2>/dev/null || echo 0)
    local failed_deploys=$(grep -c "部署失败" "$DEPLOY_LOG" 2>/dev/null || echo 0)
    
    log "INFO" "📊 部署统计:"
    log "INFO" "   总部署次数: $total_deploys"
    log "INFO" "   成功次数: $success_deploys"
    log "INFO" "   失败次数: $failed_deploys"
    
    if [ "$total_deploys" -gt 0 ]; then
        local success_rate=$((success_deploys * 100 / total_deploys))
        log "INFO" "   成功率: ${success_rate}%"
    fi
}
# ================================================

# ==================== 主流程 ====================
main() {
    local start_time=$(date +%s)
    
    log "INFO" "============================================================"
    log "INFO" "🚀 绮管电商后台 - 自动部署流程启动"
    log "INFO" "============================================================"
    log "INFO" "服务器: ${SERVER_IP} (${DOMAIN})"
    log "INFO" "工作目录: ${WORK_TREE}"
    log "INFO" "部署时间: $(date "$DATE_FORMAT")"
    log "INFO" "============================================================"
    
    # 1. 获取部署锁
    acquire_lock
    
    # 读取Git推送信息
    while read oldrev newrev refname; do
        BRANCH=$(echo "$refname" | sed 's|refs/heads/||')
        
        log "INFO" "📥 收到推送信息:"
        log "INFO" "   分支: ${BRANCH}"
        log "INFO" "   旧版本: ${oldrev:0:8}"
        log "INFO" "   新版本: ${newrev:0:8}"
        
        # 仅处理 绮管 分支
        if [ "$BRANCH" != "绮管" ]; then
            log "INFO" "⏭️ 跳过分支: ${BRANCH} (仅处理 '绮管' 分支)"
            continue
        fi
        
        log "INFO" "✅ 检测到目标分支: 绮管，开始部署流程..."
        
        # 2. 健康检查
        health_check
        
        # 3. 备份当前版本
        backup_current_version
        
        # 4. 检出代码
        log "INFO" "📂 正在检出代码到工作目录..."
        GIT_WORK_TREE="$WORK_TREE" git checkout -f "$BRANCH" || \
            error_exit "代码检出失败"
        log "SUCCESS" "✅ 代码检出成功"
        
        # 5. 安装依赖
        install_dependencies
        
        # 6. 构建项目
        build_project
        
        # 7. 重启服务
        restart_services
        
        # 8. 健康验证
        verify_deployment
        
        # 9. 清理旧日志
        cleanup_old_logs
        
        # 10. 计算部署耗时
        local end_time=$(date +%s)
        local duration=$((end_time - start_time))
        local minutes=$((duration / 60))
        local seconds=$((duration % 60))
        
        log "INFO" "============================================================"
        log "SUCCESS" "✅ 部署完成！"
        log "INFO" "------------------------------------------------------------"
        log "INFO" "📍 分支: ${BRANCH}"
        log "INFO" "📍 工作目录: ${WORK_TREE}"
        log "INFO" "📍 日志文件: ${LOG_DIR}/deploy_${TIMESTAMP}.log"
        log "INFO" "📍 备份目录: ${BACKUP_DIR}/${TIMESTAMP}"
        log "INFO" "📍 部署耗时: ${minutes}分${seconds}秒 (${duration}秒)"
        log "INFO" "📍 PM2进程: ${PM2_BACKEND}, ${PM2_FRONTEND}"
        log "INFO" "============================================================"
        
        # 11. 显示部署统计
        show_deploy_stats
        
        # 12. 发送成功通知
        send_notification "DEPLOY_SUCCESS" "部署成功！分支: ${BRANCH}, 耗时: ${minutes}分${seconds}秒"
        
        success_exit "部署流程完成"
    done
}

# 执行主函数
main "$@"
