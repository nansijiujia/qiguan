{
  "name": "orders",
  "displayName": "订单管理",
  "description": "订单信息管理",
  "fields": [
    {
      "name": "orderNo",
      "displayName": "订单号",
      "type": "string",
      "required": true
    },
    {
      "name": "userId",
      "displayName": "用户ID",
      "type": "string",
      "required": true
    },
    {
      "name": "userName",
      "displayName": "用户名",
      "type": "string",
      "required": true
    },
    {
      "name": "items",
      "displayName": "订单商品",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "string"
          },
          "productName": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "quantity": {
            "type": "number"
          }
        }
      },
      "required": true
    },
    {
      "name": "totalAmount",
      "displayName": "总金额",
      "type": "number",
      "required": true
    },
    {
      "name": "status",
      "displayName": "订单状态",
      "type": "string",
      "required": true,
      "defaultValue": "pending",
      "enum": ["pending", "paid", "shipped", "completed", "cancelled"]
    },
    {
      "name": "shippingAddress",
      "displayName": "收货地址",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "address": {
          "type": "string"
        }
      },
      "required": false
    },
    {
      "name": "createdAt",
      "displayName": "创建时间",
      "type": "timestamp",
      "required": true,
      "autoGenerate": true
    },
    {
      "name": "updatedAt",
      "displayName": "更新时间",
      "type": "timestamp",
      "required": true,
      "autoGenerate": true
    }
  ]
}