# ============================================================
# 绮管电商后台 - 环境变量配置模板
# ============================================================
# 使用说明:
#   1. 复制此文件为 .env: cp .env.example .env
#   2. 根据实际环境修改配置值
#   3. 运行配置验证: bash scripts/setup_env.sh -v
#   4. 设置文件权限: chmod 600 .env
#
# 安全提示:
#   • 不要将 .env 文件提交到版本控制系统
#   • 密码和密钥使用强随机字符串
#   • 生产环境必须修改所有默认值
#   • 定期轮换密钥和密码
#
# 作者: 绮管技术团队
# 最后更新: 2026-04-08
# ============================================================

# ==================== 应用基础配置 ====================

# 服务端口 (后端API监听端口)
# 推荐范围: 3000-9999, 避免使用系统保留端口 (<1024)
PORT=3000

# Node.js 运行环境
# 可选值:
#   - production: 生产环境 (关闭调试, 优化性能)
#   - staging:    测试环境 (接近生产, 允许测试接口)
#   - development: 开发环境 (开启调试, 详细错误)
#   - test:       单元测试环境
NODE_ENV=production

# 调试模式 (仅开发环境建议开启)
# 生产环境必须设置为 false
DEBUG=false

# 日志级别
# 可选值: error, warn, info, debug, trace
LOG_LEVEL=info

# 应用名称 (用于日志和标识)
APP_NAME=qiguan-backend

# 应用版本
APP_VERSION=1.0.0


# ==================== 数据库配置 ====================

# 数据库类型
# 可选值:
#   - mysql: MySQL/MariaDB (推荐生产环境)
#   - sqlite: SQLite (适合开发/小型部署)
DB_TYPE=mysql

# ---- MySQL 配置 (当 DB_TYPE=mysql 时生效) ----

# 数据库主机地址
# 本地: localhost 或 127.0.0.1
# 远程: 数据库服务器IP或域名
DB_HOST=localhost

# 数据库端口
# MySQL 默认: 3306
DB_PORT=3306

# 数据库名称
# 建议为每个环境使用独立数据库
DB_NAME=qiguan

# 数据库用户名
# 生产环境不要使用 root 用户，创建专用用户
DB_USER=root

# 数据库密码
# ⚠️ 必须修改为强密码!
# 建议: 至少16位，包含大小写字母、数字、特殊字符
DB_PASSWORD=your_secure_password_here

# 连接池配置
# 最大连接数 (根据服务器性能调整)
DB_POOL_MAX=10
# 最小空闲连接数
DB_POOL_MIN=2
# 连接超时时间 (毫秒)
DB_CONNECTION_TIMEOUT=60000
# 获取连接超时 (毫秒)
DB_ACQUIRE_TIMEOUT=60000

# ---- SQLite 配置 (当 DB_TYPE=sqlite 时生效) ----

# SQLite 数据库文件路径
# 确保目录存在且有写入权限
DB_PATH=/var/www/qiguan/data/ecommerce.db


# ==================== JWT 认证配置 ====================

# JWT 密钥 (用于签名Token)
# ⚠️⚠️⚠️ 极其重要! 必须修改! ⚠️⚠️⚠️
# 要求:
#   - 长度至少 32 个字符 (推荐 64+ 字符)
#   - 使用强随机字符串
#   - 定期更换密钥 (会导致所有Token失效)
#
# 生成方法:
#   openssl rand -base64 48
#   或运行: bash scripts/setup_env.sh -q
JWT_SECRET=your-super-secret-key-at-least-32-characters-long!!!

# Token 过期时间
# 格式: 数字+单位 (s=秒, m=分, h=小时, d=天)
# 推荐:
#   - 开发环境: 24h 或更长
#   - 生产环境: 2h-8h (安全考虑)
#   - 移动端App: 7d-30d (用户体验考虑)
JWT_EXPIRES_IN=24h

# JWT 签名算法
# 可选值: HS256, HS384, HS512
# HS256: 性能好, 安全性足够
# HS512: 更高安全性, 性能略低
JWT_ALGORITHM=HS256

# Refresh Token 过期时间 (如果实现刷新机制)
# 通常比 Access Token 长 5-10 倍
JWT_REFRESH_EXPIRES_IN=7d

# Token 发布者标识
JWT_ISSUER=qiguan-api

# Token 受众 (API端点URL)
JWT_AUDIENCE=https://api.qimengzhiyue.cn


# ==================== 服务器配置 ====================

# 服务器主机名或IP (用于生成链接)
HOST=localhost

# API 基础路径
API_PREFIX=/api

# API 版本
API_VERSION=v1

# 请求体大小限制 (用于文件上传等场景)
# 格式: 数字+单位 (kb, mb, gb)
BODY_SIZE_LIMIT=50mb

# 请求超时时间 (毫秒)
REQUEST_TIMEOUT=30000

# CORS 跨域配置
# 允许的来源 (逗号分隔, * 表示允许所有)
CORS_ORIGIN=*

# 是否启用 CORS 凭证 (cookies/authorization headers)
CORS_CREDENTIALS=true

# 信任代理 (在反向代理后面时设置为true)
TRUST_PROXY=true

# 信任的代理数量 (Nginx层数)
TRUST_PROXY_COUNT=1


# ==================== 会话与缓存配置 ====================

# 会话密钥 (如果使用session-based认证)
SESSION_SECRET=change-this-to-a-random-secret

# Cookie 配置
COOKIE_NAME=qiguan_session
COOKIE_MAX_AGE=86400000  # 24小时 (毫秒)
COOKIE_SECURE=true        # 仅HTTPS传输 (生产环境必须true)
COOKIE_HTTPONLY=true      # 防止XSS攻击
COOKIE_SAME_SITE=strict   # CSRF保护

# Redis 缓存配置 (可选, 如果使用Redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=3600  # 缓存过期时间(秒)


# ==================== 文件上传配置 ====================

# 上传文件存储路径
UPLOAD_DIR=/var/www/qiguan/uploads

# 允许的文件类型 (MIME类型, 逗号分隔)
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf

# 单个文件大小限制 (字节)
UPLOAD_MAX_FILESIZE=10485760  # 10MB

# 总上传大小限制 (字节)
UPLOAD_MAX_TOTAL=52428800     # 50MB

# 上传文件URL前缀
UPLOAD_URL_PREFIX=/uploads


# ==================== 日志配置 ====================

# 日志输出方式
# 可选值: console, file, both
LOG_OUTPUT=file

# 日志文件路径
LOG_DIR=/var/log/qiguan
LOG_FILE_ERROR=error.log
LOG_FILE_COMBINED=combined.log

# 日志文件大小限制 (达到后自动轮转)
LOG_MAX_SIZE=20m

# 保留的日志文件数量
LOG_MAX_FILES=14

# 是否压缩旧日志文件
LOG_COMPRESS=true


# ==================== 邮件服务配置 (可选) ====================

# SMTP 服务器
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-app-password
MAIL_FROM=noreply@qimengzhiyue.cn
MAIL_SECURE=false  # TLS使用587, SSL使用465


# ==================== 第三方服务配置 (可选) ====================

# 云开发环境ID (腾讯云CloudBase)
CLOUDBASE_ENV=

# 腾讯云密钥 (用于调用云API)
SECRET_ID=
SECRET_KEY=

# 对象存储 (COS/OSS) 配置
# 如果需要文件上传到云存储
COS_BUCKET=
COS_REGION=
COS_SECRET_ID=
COS_SECRET_KEY=

# 短信服务配置 (阿里云/腾讯云)
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

# 支付配置 (微信支付/支付宝)
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=


# ==================== 监控与分析 (可选) ====================

# 是否启用性能监控
ENABLE_MONITORING=false

# 监控数据上报地址
MONITORING_ENDPOINT=

# Google Analytics / 百度统计 ID (前端使用)
GA_TRACKING_ID=
BAIDU_ANALYTICS_ID=

# Sentry 错误追踪 DSN
SENTRY_DSN=


# ==================== 功能开关 ====================

# 是否启用注册功能
ENABLE_REGISTRATION=true

# 是否需要邮箱验证
REQUIRE_EMAIL_VERIFICATION=false

# 是否启用速率限制
ENABLE_RATE_LIMIT=true

# API请求频率限制 (每分钟请求数)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# 是否启用API文档 (Swagger)
ENABLE_SWAGGER=true
SWAGGER_PATH=/api-docs


# ==================== 安全相关 ====================

# 是否强制HTTPS (生产环境建议开启)
ENFORCE_HTTPS=true

# Helmet安全头配置
HELMET_CROSS_ORIGIN_RESOURCE_POLICY=same-origin
HELMET_ORIGIN_AGENT_CLUSTER=?1

# CSP 内容安全策略 (可选, 高级安全配置)
# CONTENT_SECURITY_POLICY=default-src 'self'

# IP白名单 (留空表示不限制, 逗号分隔)
IP_WHITELIST=

# IP黑名单 (逗号分隔)
IP_BLACKLIST=


# ==================== 开发环境专用 (生产环境忽略) ====================

# 是否显示详细错误堆栈
SHOW_STACK_TRACE=false

# 是否启用热重载 (nodemon)
ENABLE_HOT_RELOAD=false

# Mock数据开关 (开发测试用)
USE_MOCK_DATA=false

# 测试数据库 (覆盖上面的DB配置)
# TEST_DB_NAME=qiguan_test


# ==================== 示例: 完整的生产环境配置 ====================
# (以下为参考, 请勿直接复制)

# PORT=3000
# NODE_ENV=production
# DEBUG=false
# LOG_LEVEL=warn
#
# DB_TYPE=mysql
# DB_HOST=rm-xxx.mysql.rds.aliyuncs.com
# DB_PORT=3306
# DB_NAME=qiguan_prod
# DB_USER=qiguan_admin
# DB_PASSWORD=Xk9#mP2$vL7@nQ4&wR8
#
# JWT_SECRET=aB3$dE7&jK9*mP2$qR5%tY8(wZ1)vB4
# JWT_EXPIRES_IN=8h
#
# HOST=api.qimengzhiyue.cn
# CORS_ORIGIN=https://admin.qimengzhiyue.cn
# TRUST_PROXY=true
#
# ENFORCE_HTTPS=true
# MAIL_HOST=smtp.exmail.qq.com
# MAIL_PORT=465
# MAIL_SECURE=true
